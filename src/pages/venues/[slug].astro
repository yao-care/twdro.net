---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { verificationLabel } from '../../lib/enums';
export async function getStaticPaths() {
  const venues = await getCollection('venues');
  return venues.map((v) => ({ params: { slug: v.id }, props: { venue: v } }));
}
const { venue } = Astro.props;
const d = venue.data;
---
<BaseLayout title={`${d.name} | twdro.net`} heroTitle={d.name} heroDesc={d.venue_type}>
  <section class="panel">
    <ul class="data-list">
      <li><span class="k">類型</span><span class="v">{d.venue_type}</span></li>
      <li><span class="k">地址</span><span class="v">{d.address ?? '—'}</span></li>
      <li><span class="k">室內</span><span class="v">{d.indoor ? '是' : '否'}</span></li>
      {d.booking_method && <li><span class="k">預約方式</span><span class="v">{d.booking_method}</span></li>}
      <li><span class="k">資料狀態</span><span class="v">{verificationLabel(d.verification)}</span></li>
    </ul>
  </section>
</BaseLayout>
