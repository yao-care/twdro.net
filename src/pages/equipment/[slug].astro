---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SourceBlock from '../../components/SourceBlock.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
export async function getStaticPaths() {
  const items = await getCollection('equipment');
  return items.map((it) => ({ params: { slug: it.id }, props: { item: it } }));
}
const { item } = Astro.props;
const d = item.data;
// 只列有值的規格，缺的安靜省略（不顯示佔位）
const rows: [string, string][] = [
  d.diameter_mm != null ? ['直徑', `${d.diameter_mm} mm`] : null,
  d.weight_g != null ? ['重量', `${d.weight_g} g`] : null,
  d.motor_type ? ['馬達', d.motor_type] : null,
  d.battery_voltage ? ['電池', d.battery_voltage] : null,
  d.list_price ? ['參考售價', d.list_price] : null,
].filter((r): r is [string, string] => r !== null);
---
<BaseLayout title={`${d.brand} ${d.model} | twdro.net`} heroTitle={`${d.brand} ${d.model}`} heroDesc="球機規格">
  <Breadcrumb items={[{ name: '首頁', href: '/' }, { name: '器材', href: '/equipment/' }, { name: `${d.brand} ${d.model}`, href: `/equipment/${item.id}/` }]} />
  {rows.length > 0 && (
    <section class="panel">
      <ul class="data-list">
        {rows.map(([k, v]) => <li><span class="k">{k}</span><span class="v">{v}</span></li>)}
      </ul>
    </section>
  )}
  {d.sources && d.sources.length > 0 && (
    <section class="panel"><SourceBlock sources={d.sources} /></section>
  )}
</BaseLayout>
