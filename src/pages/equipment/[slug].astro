---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SourceBlock from '../../components/SourceBlock.astro';
export async function getStaticPaths() {
  const items = await getCollection('equipment');
  return items.map((it) => ({ params: { slug: it.id }, props: { item: it } }));
}
const { item } = Astro.props;
const d = item.data;
---
<BaseLayout title={`${d.brand} ${d.model} | twdro.net`} heroTitle={`${d.brand} ${d.model}`} heroDesc="球機規格">
  <section class="panel">
    <ul class="data-list">
      <li><span class="k">直徑</span><span class="v">{d.diameter_mm ?? '—'} mm</span></li>
      <li><span class="k">重量</span><span class="v">{d.weight_g ?? '—'} g</span></li>
      <li><span class="k">馬達</span><span class="v">{d.motor_type ?? '—'}</span></li>
      <li><span class="k">電池</span><span class="v">{d.battery_voltage ?? '—'}</span></li>
      <li><span class="k">參考售價</span><span class="v">{d.list_price ?? '—'}</span></li>
    </ul>
  </section>
  {d.sources && d.sources.length > 0 && (
    <section class="panel"><SourceBlock sources={d.sources} verification="community_submitted" /></section>
  )}
</BaseLayout>
