---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { url } from '../../lib/url';
import { LEARN_CATEGORY_ORDER, learnCategoryLabel } from '../../lib/enums';
const articles = (await getCollection('learn')).sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout title="認識無人機足球 | twdro.net" heroTitle="認識無人機足球" heroDesc="從入門、規則、器材到參賽與教學，一次讀懂無人機足球。">
  {LEARN_CATEGORY_ORDER.map((cat) => {
    const list = articles.filter((a) => a.data.category === cat);
    return list.length ? (
      <section>
        <h2 class="group-title">{learnCategoryLabel(cat)}</h2>
        <ul class="card-grid">
          {list.map((a) => (
            <li>
              <a class="card-link" href={url(`/learn/${a.id}`)}>
                <span class="name">{a.data.title}</span>
                {a.data.description && <span class="meta">{a.data.description}</span>}
              </a>
            </li>
          ))}
        </ul>
      </section>
    ) : null;
  })}
</BaseLayout>
