---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SPEC_FIELDS, SYSTEM_LABELS } from '../../lib/compare';
const books = (await getCollection('rulebooks')).map((b) => ({
  id: b.id,
  name: b.data.name,
  system: SYSTEM_LABELS[b.data.rule_system] ?? b.data.rule_system,
  spec: b.data.competition_spec ?? {},
}));
const dataJson = JSON.stringify({ books, fields: SPEC_FIELDS });
---
<BaseLayout
  title="規則比較器 | twdro.net"
  description="並排比較 FAI、FIDA、教育部等不同無人機足球規則的賽制規格。"
  heroTitle="規則比較器"
  heroDesc="勾選要比較的規則版本。不同體系規則各自獨立，請勿視為可互換。"
>
  <fieldset id="book-picker" class="panel" style="border:1px solid var(--color-border);margin:0 0 20px">
    {books.map((b) => (
      <label style="display:inline-block;margin:.3rem 1.5rem .3rem 0">
        <input type="checkbox" value={b.id} checked /> {b.name}
      </label>
    ))}
  </fieldset>
  <div class="panel" style="overflow-x:auto"><div id="compare-result"></div></div>
  <script type="application/json" id="compare-data" set:html={dataJson} />
  <script>
    import { compareRulebooks } from '../../lib/compare';
    const raw = document.getElementById('compare-data')!.textContent!;
    const { books } = JSON.parse(raw) as { books: { id: string; name: string; system?: string; spec: Record<string, any> }[] };
    const picker = document.getElementById('book-picker')!;
    const result = document.getElementById('compare-result')!;

    const thStyle = 'text-align:left;padding:.6rem .7rem;border-bottom:2px solid var(--color-border)';
    const tdStyle = 'padding:.6rem .7rem;border-bottom:1px solid var(--color-border)';
    const kdStyle = 'text-align:left;padding:.6rem .7rem;border-bottom:1px solid var(--color-border);color:var(--color-text-muted);font-weight:600';

    function el(tag: string, style: string, text?: string) {
      const node = document.createElement(tag);
      node.setAttribute('style', style);
      if (text !== undefined) node.textContent = text; // 安全：不用 innerHTML 插入 spec 值
      return node;
    }

    function render() {
      const checked = Array.from(picker.querySelectorAll('input:checked')).map((i) => (i as HTMLInputElement).value);
      const selected = books.filter((b) => checked.includes(b.id));
      result.replaceChildren();
      if (selected.length === 0) {
        result.appendChild(el('p', 'color:var(--color-text-muted)', '請至少勾選一個規則版本。'));
        result.firstElementChild!.className = 'text-muted';
        return;
      }
      const rows = compareRulebooks(selected);

      const table = document.createElement('table');
      table.className = 'data-table';
      table.setAttribute('style', 'min-width:100%');

      // 表頭：欄位 + 各規則書（標明體系）
      const thead = document.createElement('thead');
      const hr = document.createElement('tr');
      hr.appendChild(el('th', thStyle, '欄位'));
      for (const b of selected) {
        const th = el('th', thStyle);
        const name = document.createElement('div');
        name.textContent = b.name;
        th.appendChild(name);
        if (b.system) {
          const sys = el('div', 'font-size:.85rem;font-weight:600;color:var(--color-text-muted)', `體系：${b.system}`);
          th.appendChild(sys);
        }
        hr.appendChild(th);
      }
      thead.appendChild(hr);
      table.appendChild(thead);

      const tbody = document.createElement('tbody');
      for (const r of rows) {
        const tr = document.createElement('tr');
        tr.appendChild(el('th', kdStyle, r.label));
        for (const v of r.values) {
          tr.appendChild(el('td', tdStyle, v === undefined || v === null || v === '' ? '—' : String(v)));
        }
        tbody.appendChild(tr);
      }
      table.appendChild(tbody);
      result.appendChild(table);
    }
    picker.addEventListener('change', render);
    render();
  </script>
</BaseLayout>
