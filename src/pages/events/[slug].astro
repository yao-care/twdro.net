---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import StatusBadge from '../../components/StatusBadge.astro';
import SourceBlock from '../../components/SourceBlock.astro';
import { eventJsonLd } from '../../lib/jsonld';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { url } from '../../lib/url';
import { isPublicEvent } from '../../lib/enums';
export async function getStaticPaths() {
  const events = await getCollection('events');
  // 草稿賽事不產生公開頁（無公開 URL）；人工把 status 升級後才會有頁面。
  return events.filter((e) => isPublicEvent(e.data.status))
    .map((e) => ({ params: { slug: e.id }, props: { event: e } }));
}
const RULE_LABEL: Record<string, string> = { FAI: 'FAI', FIDA: 'FIDA', MOE: '教育部', OTHER: '民間賽事' };
const { event } = Astro.props;
const d = event.data;
const isOpen = d.status === 'registration_open';
const jsonld = eventJsonLd({
  name: d.title,
  startDate: d.schedule.event_start,
  endDate: d.schedule.event_end,
  url: new URL(url(`/events/${event.id}`), Astro.site).toString(),
  locationName: d.schedule.venue_name,
});

const levels = d.eligibility.education_levels ?? [];
const hasTeamSize = d.eligibility.team_size_min != null || d.eligibility.team_size_max != null;
const teamSizeText = [d.eligibility.team_size_min, d.eligibility.team_size_max].every((n) => n != null)
  ? `${d.eligibility.team_size_min}–${d.eligibility.team_size_max} 人`
  : `${d.eligibility.team_size_min ?? d.eligibility.team_size_max} 人`;
const showEligibility = levels.length > 0 || hasTeamSize;
const showCompetition = d.competition.drone_class != null
  || d.competition.drone_diameter != null
  || d.competition.active_drones_per_team != null;
const r = d.results;
const showResults = !!r && (r.champion_team || r.runner_up_team || r.third_place_team);
---
<BaseLayout title={`${d.title} | twdro.net`} description={d.subtitle} heroTitle={d.title} heroDesc={d.subtitle}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonld)} />
  <Breadcrumb items={[{ name: '首頁', href: '/' }, { name: '賽事', href: '/events/' }, { name: d.title, href: `/events/${event.id}/` }]} />

  <section class="panel" style="display:flex;flex-wrap:wrap;align-items:center;gap:16px;justify-content:space-between;margin-bottom:20px">
    <StatusBadge status={d.status} />
    {d.registration_url && (
      <a class="btn-action" href={d.registration_url} rel="nofollow noopener" target="_blank" style={isOpen ? '' : 'background:var(--color-brand);color:#fff'}>
        {isOpen ? '立即報名 →' : '前往報名 ↗'}
      </a>
    )}
  </section>

  <section class="panel">
    <h2>基本資訊</h2>
    <ul class="data-list">
      {d.event_series && <li><span class="k">賽事系列</span><span class="v">{d.event_series}</span></li>}
      {d.event_type && <li><span class="k">賽事類型</span><span class="v">{d.event_type}</span></li>}
      {d.level && <li><span class="k">層級</span><span class="v">{d.level}</span></li>}
      <li><span class="k">主辦</span><span class="v">{d.organizer ?? '—'}</span></li>
      <li><span class="k">規則體系</span><span class="v">{RULE_LABEL[d.rule_system] ?? d.rule_system}</span></li>
      {d.rulebook && <li><span class="k">規則書</span><span class="v"><a href={url(`/rules/${d.rulebook}`)} style="font-weight:650">查看規則書 →</a></span></li>}
      <li><span class="k">日期</span><span class="v">{d.schedule.event_start ?? '未定'}</span></li>
      <li><span class="k">地點</span><span class="v">{[d.schedule.city, d.schedule.venue_name].filter(Boolean).join(' · ') || '—'}</span></li>
      {d.schedule.registration_end && <li><span class="k">報名截止</span><span class="v">{d.schedule.registration_end}</span></li>}
    </ul>
  </section>

  {showEligibility && (
    <section class="panel">
      <h2>參賽資格</h2>
      <ul class="data-list">
        {levels.length > 0 && <li><span class="k">組別</span><span class="v">{levels.join('、')}</span></li>}
        {hasTeamSize && <li><span class="k">隊伍人數</span><span class="v">{teamSizeText}</span></li>}
      </ul>
    </section>
  )}

  {showCompetition && (
    <section class="panel">
      <h2>球機規格</h2>
      <ul class="data-list">
        {d.competition.drone_class != null && <li><span class="k">級別</span><span class="v">{d.competition.drone_class}</span></li>}
        {d.competition.drone_diameter != null && <li><span class="k">直徑</span><span class="v">{d.competition.drone_diameter}</span></li>}
        {d.competition.active_drones_per_team != null && <li><span class="k">場上球機</span><span class="v">{d.competition.active_drones_per_team}</span></li>}
      </ul>
    </section>
  )}

  {showResults && (
    <section class="panel">
      <h2>成績</h2>
      <ul class="data-list">
        {r?.champion_team && <li><span class="k">冠軍</span><span class="v">{r.champion_team}</span></li>}
        {r?.runner_up_team && <li><span class="k">亞軍</span><span class="v">{r.runner_up_team}</span></li>}
        {r?.third_place_team && <li><span class="k">季軍</span><span class="v">{r.third_place_team}</span></li>}
      </ul>
    </section>
  )}

  <section class="panel">
    <SourceBlock sources={d.sources} verification={d.verification} />
  </section>
</BaseLayout>
