---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import EventCard from '../components/EventCard.astro';
import { url } from '../lib/url';

const today = new Date().toISOString().slice(0, 10);
const ACTIVE = ['registration_open', 'announced', 'ongoing'];
const events = await getCollection('events');
// 有日期者排前（升冪），無日期者排後
const byDate = [...events].sort((a, b) => {
  const da = a.data.schedule.event_start ?? '';
  const db = b.data.schedule.event_start ?? '';
  if (!da) return 1; if (!db) return -1;
  return da.localeCompare(db);
});
const upcoming = byDate.filter((e) => (e.data.schedule.event_start ?? '') >= today && ACTIVE.includes(e.data.status));
const next = upcoming[0] ?? events.find((e) => ACTIVE.includes(e.data.status)) ?? byDate[0];
// 近期：即將到來的優先，補上最近的其他賽事
const recent = [...upcoming, ...byDate.filter((e) => !upcoming.includes(e))].slice(0, 4);

const news = (await getCollection('news')).sort((a, b) => b.data.date.localeCompare(a.data.date)).slice(0, 3);

const tools = [
  ['/rules/compare', '規則比較器', '並排比較 FAI／FIDA／教育部賽制'],
  ['/equipment/compliance-check', '球機合規檢查器', '輸入規格初步比對是否符合'],
  ['/events/calendar', '賽事日曆', '依狀態與月份篩選賽事'],
  ['/teams', '隊伍名錄', '學校與俱樂部隊伍'],
  ['/venues', '場地地圖', '練習與比賽場地'],
  ['/organizations', '推廣單位', '協會、學校、廠商與政府單位'],
  ['/search', '全站搜尋', '搜尋賽事、規則、器材'],
];
---
<BaseLayout title="臺灣無人機足球的賽事、規則與器材 | twdro.net" bare>
  <section class="page-hero">
    <div class="page-hero__inner" style="padding-block:80px 72px">
      <p style="color:var(--color-tech);font-weight:700;letter-spacing:0.12em;margin:0 0 14px;font-size:0.95rem">TAIWAN DRONE SOCCER · 無人機足球</p>
      <h1 style="font-size:clamp(2.6rem,6vw,4.2rem);max-width:18ch">臺灣無人機足球的賽事、規則與器材</h1>
      <p>整理各地賽事、FAI／FIDA／教育部規則、隊伍、場地與器材規格，每筆標明來源與查核日期。</p>
      <div style="display:flex;gap:14px;flex-wrap:wrap;margin-top:28px">
        <a class="btn-action" href={url('/events')}>查看近期賽事 →</a>
        <a class="btn-outline" href={url('/learn')}>認識無人機足球</a>
      </div>
    </div>
  </section>

  <div class="page-content">
    {next && (
      <section style="margin-bottom:56px">
        <h2 style="margin:0 0 18px">下一場比賽</h2>
        <EventCard
          id={next.id}
          title={next.data.title}
          status={next.data.status}
          eventStart={next.data.schedule.event_start}
          city={next.data.schedule.city}
          venue={next.data.schedule.venue_name}
          registrationEnd={next.data.schedule.registration_end}
          registrationUrl={next.data.registration_url}
        />
      </section>
    )}

    <section style="margin-bottom:56px">
      <div style="display:flex;align-items:baseline;justify-content:space-between;gap:16px;margin-bottom:18px">
        <h2 style="margin:0">近期賽事</h2>
        <a href={url('/events')} style="font-weight:650">全部賽事 →</a>
      </div>
      <div style="display:grid;gap:18px">
        {recent.map((e) => (
          <EventCard
            id={e.id}
            title={e.data.title}
            status={e.data.status}
            eventStart={e.data.schedule.event_start}
            city={e.data.schedule.city}
            venue={e.data.schedule.venue_name}
            registrationEnd={e.data.schedule.registration_end}
            registrationUrl={e.data.registration_url}
          />
        ))}
      </div>
    </section>

    {news.length > 0 && (
      <section style="margin-bottom:56px">
        <div style="display:flex;align-items:baseline;justify-content:space-between;gap:16px;margin-bottom:18px">
          <h2 style="margin:0">最新消息</h2>
          <a href={url('/news')} style="font-weight:650">全部消息 →</a>
        </div>
        <div style="display:grid;gap:14px">
          {news.map((n) => (
            n.data.source_url ? (
              <a class="card-link" href={n.data.source_url} rel="nofollow noopener" target="_blank">
                <span class="meta" style="margin-top:0">{n.data.date}</span>
                <span class="name" style="margin-top:4px">{n.data.title} ↗</span>
                {n.data.source_publisher && <span class="meta" style="margin-top:4px">來源：{n.data.source_publisher}</span>}
              </a>
            ) : (
              <div class="card-link" style="cursor:default">
                <span class="meta" style="margin-top:0">{n.data.date}</span>
                <span class="name" style="margin-top:4px">{n.data.title}</span>
              </div>
            )
          ))}
        </div>
      </section>
    )}

    <section>
      <h2 style="margin:0 0 18px">工具與資料</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(15rem,1fr));gap:16px">
        {tools.map(([href, name, desc]) => (
          <a href={url(href)} style="display:block;background:var(--color-surface);border:1px solid var(--color-border);border-radius:14px;padding:22px 24px;text-decoration:none">
            <span style="display:block;font-size:1.2rem;font-weight:750;color:var(--color-text)">{name}</span>
            <span style="display:block;margin-top:6px;color:var(--color-text-muted);font-size:0.95rem">{desc}</span>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
