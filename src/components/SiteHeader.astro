---
import { url } from '../lib/url';
const nav = [
  ['/events', '賽事'], ['/rules', '規則'], ['/teams', '隊伍'],
  ['/equipment', '器材'], ['/learn', '認識無人機足球'], ['/about', '關於'], ['/search', '搜尋'],
];
const path = Astro.url.pathname.replace(/\/$/, '');
const isCurrent = (href: string) => {
  const full = url(href).replace(/\/$/, '');
  return path === full || path.startsWith(full + '/');
};
---
<header class="site-header">
  <div class="site-header__inner">
    <a href={url('/')} class="site-logo">
      <span class="site-logo__domain">twdro.net</span>
      <span class="site-logo__name">臺灣無人機足球</span>
    </a>
    <nav class="site-nav">
      {nav.map(([href, label]) => (
        <a href={url(href)} aria-current={isCurrent(href) ? 'page' : undefined}>{label}</a>
      ))}
    </nav>
  </div>
</header>
