---
import { url } from '../lib/url';
const nav = [
  ['/events', '賽事'], ['/rules', '規則'], ['/teams', '隊伍'],
  ['/equipment', '器材'], ['/learn', '認識無人機足球'], ['/about', '關於'], ['/search', '搜尋'],
];
const path = Astro.url.pathname.replace(/\/$/, '');
const isCurrent = (href: string) => {
  const full = url(href).replace(/\/$/, '');
  return path === full || path.startsWith(full + '/');
};
---
<header class="site-header">
  <div class="site-header__inner">
    <a href={url('/')} class="site-logo" aria-label="twdro.net — 臺灣無人機足球">
      <span class="site-logo__domain" aria-hidden="true"
        ><span class="dim">tw</span><span class="drone">dro<svg
            class="site-logo__ball" viewBox="0 0 32 32" role="img" aria-hidden="true"
            ><g class="site-logo__ball-inner"
              ><circle class="halo" cx="16" cy="16" r="15"></circle
              ><circle class="core" cx="16" cy="16" r="8.5"></circle
              ><ellipse class="cage" cx="16" cy="16" rx="8.5" ry="3.4"></ellipse
              ><ellipse class="cage" cx="16" cy="16" rx="3.4" ry="8.5"></ellipse
            ></g
          ></svg>ne</span><span class="dim">t</span></span>
      <span class="site-logo__name">臺灣無人機足球</span>
    </a>
    <nav class="site-nav">
      {nav.map(([href, label]) => (
        <a href={url(href)} aria-current={isCurrent(href) ? 'page' : undefined}>{label}</a>
      ))}
    </nav>
  </div>
</header>
