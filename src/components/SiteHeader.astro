---
import { url } from '../lib/url';
const nav = [
  ['/events', '賽事'], ['/rules', '規則'], ['/teams', '隊伍'],
  ['/equipment', '器材'], ['/learn', '認識無人機足球'], ['/about', '關於'], ['/search', '搜尋'],
];
const path = Astro.url.pathname.replace(/\/$/, '');
const isCurrent = (href: string) => {
  const full = url(href).replace(/\/$/, '');
  return path === full || path.startsWith(full + '/');
};
---
<header class="site-header">
  <div class="site-header__inner">
    <a href={url('/')} class="site-logo" aria-label="twdro.net — 臺灣無人機足球">
      <span class="site-logo__domain" aria-hidden="true"
        ><span class="dim">tw</span><span class="word">dro</span><span class="site-logo__net"
          ><span class="word">ne</span><span class="dim">t</span
          ><i class="site-logo__ball"></i></span></span>
      <span class="site-logo__name">臺灣無人機足球</span>
    </a>
    <button class="site-nav-toggle" type="button" aria-expanded="false" aria-controls="site-nav" aria-label="開啟選單">
      <span class="site-nav-toggle__bar"></span>
      <span class="site-nav-toggle__bar"></span>
      <span class="site-nav-toggle__bar"></span>
    </button>
    <nav class="site-nav" id="site-nav">
      {nav.map(([href, label]) => (
        <a href={url(href)} aria-current={isCurrent(href) ? 'page' : undefined}>{label}</a>
      ))}
    </nav>
  </div>
</header>
<script>
  const toggle = document.querySelector<HTMLButtonElement>('.site-nav-toggle');
  const inner = toggle?.closest('.site-header__inner');
  toggle?.addEventListener('click', () => {
    const open = inner?.classList.toggle('nav-open') ?? false;
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? '關閉選單' : '開啟選單');
  });
</script>
