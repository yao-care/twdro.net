---
import { url } from '../lib/url';
const links = [
  ['/about', '關於本站'], ['/about/sources', '資料來源'], ['/about/correction', '回報資料錯誤'],
  ['/about/privacy', '隱私權政策'], ['/about/terms', '使用條款'], ['/about/disclaimer', '免責聲明'],
];
---
<footer class="site-footer">
  <div class="site-footer__inner">
    <p class="site-footer__brand">twdro.net</p>
    <p class="site-footer__tag">台灣無人機足球資料與賽事平台</p>
    <nav class="site-footer__links">
      {links.map(([href, label]) => <a href={url(href)}>{label}</a>)}
    </nav>
  </div>
</footer>
