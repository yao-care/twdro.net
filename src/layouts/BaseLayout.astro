---
import '../styles/tokens.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
interface Props {
  title: string;
  description?: string;
  lang?: string;
  heroTitle?: string;
  heroDesc?: string;
  bare?: boolean;
}
const {
  title,
  description = '整合台灣無人機足球賽事、規則、隊伍、場地與器材的入口平台。',
  lang = 'zh-Hant',
  heroTitle,
  heroDesc,
  bare = false,
} = Astro.props;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <slot name="head" />
  </head>
  <body>
    <SiteHeader />
    {bare ? (
      <main><slot /></main>
    ) : heroTitle ? (
      <main>
        <section class="page-hero">
          <div class="page-hero__inner">
            <h1>{heroTitle}</h1>
            {heroDesc && <p>{heroDesc}</p>}
          </div>
        </section>
        <div class="page-content"><slot /></div>
      </main>
    ) : (
      <main class="container" style="padding-block: var(--space-7) var(--space-9)"><slot /></main>
    )}
    <SiteFooter />
  </body>
</html>
